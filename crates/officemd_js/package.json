{
  "name": "office-md",
  "version": "0.1.0",
  "description": "Native Node/Bun bindings for OfficeMD document extraction",
  "license": "MIT",
  "author": "Thomas Aubry",
  "homepage": "https://github.com/ThomAub/officemd",
  "bugs": {
    "url": "https://github.com/ThomAub/officemd/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThomAub/officemd.git",
    "directory": "crates/officemd_js"
  },
  "keywords": [
    "officemd",
    "office",
    "docx",
    "xlsx",
    "csv",
    "pdf",
    "markdown"
  ],
  "bin": {
    "office-md": "cli.js"
  },
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "napi": {
    "name": "office-md",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "aarch64-pc-windows-msvc",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "test:cli": "node --test tests/cli-selection.test.mjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "files": [
    "index.js",
    "index.d.ts",
    "cli.js",
    "lib",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "diff": "^7.0.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0"
  },
  "optionalDependencies": {
    "office-md-win32-x64-msvc": "0.1.0",
    "office-md-darwin-x64": "0.1.0",
    "office-md-linux-x64-gnu": "0.1.0",
    "office-md-darwin-arm64": "0.1.0",
    "office-md-linux-arm64-gnu": "0.1.0",
    "office-md-linux-arm64-musl": "0.1.0",
    "office-md-win32-arm64-msvc": "0.1.0",
    "office-md-linux-x64-musl": "0.1.0"
  }
}